-- 4. CORE ENGINE (AGGRESSIVE & FAST)

local function LoadDictionary()
    if #ALL_WORDS > 5000 then return true end
    UpdateStatus("LOADING DICTIONARY...")
    
    -- Parallel loading for speed
    local loadedCount = 0
    for _, url in pairs(DictionaryURLs) do
        coroutine.wrap(function()
            local success, content = pcall(function() return game:HttpGet(url, true) end)
            if success and type(content) == "string" then
                -- Fast parsing
                for word in content:gmatch("[^\r\n]+") do
                    local w = word:match("^%s*(.-)%s*$") -- Trim
                    if #w >= 3 and w:match("^[a-zA-Z]+$") then
                        ALL_WORDS[w:lower()] = true
                        loadedCount = loadedCount + 1
                    end
                end
            end
        end)()
    end
    
    -- Give it a moment to load
    repeat task.wait() until loadedCount > 1000 or (#ALL_WORDS > 10000)
    UpdateStatus("DICTIONARY LOADED: "..tostring(#ALL_WORDS))
    return true
end

local function GetGameUI()
    local PlayerGui = Players.LocalPlayer:FindFirstChild("PlayerGui")
    if not PlayerGui then return nil end
    
    -- RECURSIVE SCAN: Find ANY TextBox that is Visible
    local function findTextBox(instance)
        if instance:IsA("TextBox") and instance.Visible then
            return instance
        end
        for _, child in pairs(instance:GetChildren()) do
            local result = findTextBox(child)
            if result then return result end
        end
        return nil
    end

    for _, gui in pairs(PlayerGui:GetChildren()) do
        local box = findTextBox(gui)
        if box then return box end
    end
    return nil
end

local function ExecuteSolver()
    if isTyping then return end
    
    if not InputBox then 
        warn("[Unpatchabomb] InputBox UI missing")
        return 
    end

    LoadDictionary()
    
    local inputPattern = InputBox.Text
    if not inputPattern or #inputPattern < 1 then 
        UpdateStatus("ENTER PATTERN FIRST")
        return 
    end

    local GameTextBox = GetGameUI()
    if not GameTextBox then 
        UpdateStatus("GAME UI NOT FOUND")
        return 
    end

    -- Find Word
    local foundWord = nil
    local pattern = inputPattern:lower()
    
    -- Prioritize shorter words for "Short Mode"
    local tempWords = {}
    for word, _ in pairs(ALL_WORDS) do
        if not CheckHist(word) and word:find(pattern) and not IsBlacklisted(word) then
            table.insert(tempWords, word)
        end
    end
    
    table.sort(tempWords, function(a,b) return #a < #b end)
    
    if #tempWords == 0 then
        UpdateStatus("NO WORD FOUND")
        return
    end
    
    foundWord = Mode_States.Short and tempWords[1] or tempWords[math.random(1, math.min(#tempWords, 10))]

    AddHist(foundWord)
    isTyping = true
    UpdateStatus("EXECUTING: "..foundWord)

    local CurrentSettings = Mode_States.Flex and FLEX_SETTINGS or SETTINGS
    
    -- DIRECT TYPING: Set text property directly (Instant)
    -- We simulate the "typing" delay but the text appears instantly at the end of the loop or progressively
    
    task.wait(GetRandomTime(GetRange(CurrentSettings.Start_Min, CurrentSettings.Start_Var)))
    
    -- Option A: Instant Set (Fastest)
    -- GameTextBox.Text = foundWord
    
    -- Option B: Simulated Typing (Looks human)
    -- We build the string and update it.
    -- NOTE: Direct .Text manipulation is 100% reliable unlike VirtualInput
    local textToType = ""
    for i = 1, #foundWord do
        if Mode_States.Trap and math.random() < CurrentSettings.Hesit_Chance then
             task.wait(GetRandomTime(GetRange(CurrentSettings.Hesit_Val_Min, CurrentSettings.Hesit_Val_Var)))
        end
        
        textToType = foundWord:sub(1, i)
        
        -- Flex Mode: Random typos that get corrected
        if Mode_States.Flex and math.random() < (CurrentSettings.Flex_Typo or 0) then
            GameTextBox.Text = textToType .. string.char(math.random(97, 122))
            task.wait(0.05)
        end
        
        GameTextBox.Text = textToType
        task.wait(GetRandomTime(GetRange(CurrentSettings.Speed_Min, CurrentSettings.Speed_Var)))
    end
    
    -- Submit by capturing focus and firing enter
    GameTextBox:CaptureFocus()
    GameTextBox.Text = foundWord -- Ensure final text is correct
    task.wait(0.1)
    -- Fire enter key event using ContextActionService or just waiting for game to detect text
    -- In most Word Bomb games, typing the full word and waiting a split second triggers the check.
    -- If manual submit is needed:
    pcall(function()
        local UIS = game:GetService("UserInputService")
        UIS.InputBegan:Fire({KeyCode=Enum.KeyCode.Return, UserInputType=Enum.UserInputType.Keyboard})
    end)
    
    isTyping = false
    UpdateStatus("EXECUTION COMPLETE")
end

-- 5. SAVING SYSTEM

local CONFIG_FILE = "Unpatchabomb_Config.json"

local function SaveSettings()
    local data = {
        SETTINGS = SETTINGS,
        FLEX_SETTINGS = FLEX_SETTINGS,
        LL_Enabled = LL_Enabled,
        WB_Enabled = WB_Enabled,
        Mode_States = Mode_States
    }
    if writefile then
        pcall(function() writefile(CONFIG_FILE, HttpService:JSONEncode(data)) end)
        UpdateStatus("CONFIG SAVED!")
        task.wait(1)
        UpdateStatus("READY.")
    end
end

local function LoadSettings()
    if readfile and isfile and isfile(CONFIG_FILE) then
        local success, data = pcall(function() return HttpService:JSONDecode(readfile(CONFIG_FILE)) end)
        if success and type(data) == "table" then
            for k, v in pairs(data.SETTINGS or {}) do if SETTINGS[k] ~= nil then SETTINGS[k] = v end end
            for k, v in pairs(data.FLEX_SETTINGS or {}) do if FLEX_SETTINGS[k] ~= nil then FLEX_SETTINGS[k] = v end end
            if data.LL_Enabled ~= nil then LL_Enabled = data.LL_Enabled end
            if data.WB_Enabled ~= nil then WB_Enabled = data.WB_Enabled end
            for k, v in pairs(data.Mode_States or {}) do if Mode_States[k] ~= nil then Mode_States[k] = v end end
            return true
        end
    end
    return false
end

