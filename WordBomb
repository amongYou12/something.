-- Enhanced toggle buttons
local function CreateToggle(text, callback)
    local Btn = Instance.new("TextButton")
    Btn.Parent = ModesGrid
    Btn.BackgroundColor3 = Color3.fromRGB(25, 25, 40)
    Btn.Text = text
    Btn.TextColor3 = Colors.SubText
    Btn.Font = Enum.Font.GothamSemibold
    Btn.TextSize = 11
    Btn.AutoButtonColor = false
    
    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 8)
    Corner.Parent = Btn
    
    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Colors.ElementHover
    Stroke.Thickness = 1
    Stroke.Transparency = 0.5
    Stroke.Parent = Btn
    
    local state = false
    
    Btn.MouseEnter:Connect(function()
        if not state then
            TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 50)}):Play()
        end
    end)
    
    Btn.MouseLeave:Connect(function()
        if not state then
            TweenService:Create(Btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(25, 25, 40)}):Play()
        end
    end)
    
    Btn.MouseButton1Click:Connect(function()
        state = not state
        if IsFunc(callback) then callback(state, Btn) end
        
        if state then
            TweenService:Create(Btn, TweenInfo.new(0.2), {
                TextColor3 = Colors.Text,
                BackgroundColor3 = Colors.Accent
            }):Play()
            TweenService:Create(Stroke, TweenInfo.new(0.2), {Color = Colors.Accent}):Play()
        else
            TweenService:Create(Btn, TweenInfo.new(0.2), {
                TextColor3 = Colors.SubText,
                BackgroundColor3 = Color3.fromRGB(25, 25, 40)
            }):Play()
            TweenService:Create(Stroke, TweenInfo.new(0.2), {Color = Colors.ElementHover}):Play()
        end
    end)
    
    return Btn
end

