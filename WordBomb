local function LoadDictionaries()
    Status.Text = "LOADING DICTIONARIES..."
    local totalWords = 0
    local uniqueWords = {}
    for _, url in ipairs(DictionaryURLs) do
        local success, content = pcall(game.HttpGet, game, url, true)
        if success and type(content) == "string" then
            for w in content:gmatch("[a-zA-Z]+") do
                local lower_w = w:lower()
                if #lower_w > 2 and not uniqueWords[lower_w] then
                    uniqueWords[lower_w] = true
                    totalWords = totalWords + 1
                end
            end
        end
    end
    
    for word, _ in pairs(uniqueWords) do
        for i = 2, math.min(#word, 4) do
            local ending = word:sub(1, i)
            if not WordEndings[ending] then WordEndings[ending] = {} end
            table.insert(WordEndings[ending], word)
        end
    end

    Status.Text = "LOADED " .. totalWords .. " WORDS. READY."
end

