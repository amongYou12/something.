local function SafeSendKey(key, hold)
    if not vim then return end
    pcall(function() 
        vim:SendKeyEvent(true, key, false, game) 
        if hold then task.wait(0.02) end 
        vim:SendKeyEvent(false, key, false, game) 
    end)
end

local function TypeWord(word, skipCount)
    if not vim or not IsValidEnglishWord(word) then 
        Status.Text = "Invalid word or no VIM"
        Status.TextColor3 = Colors.Error
        isTyping = false
        return 
    end
    
    isTyping = true
    local isFlex = FlexT.Text:find("ON")
    local currentSettings = isFlex and FLEX_SETTINGS or SETTINGS
    
    local speedRange, startRange
    
    if GlobalEnv._UPB_Psych_State.Toying then
        speedRange = {0.01, 0.02}
        startRange = {0.0, 0.0}
        GlobalEnv._UPB_Psych_State.Toying = false
    else
        speedRange = GetRange(currentSettings.Speed_Min, currentSettings.Speed_Var)
        startRange = GetRange(currentSettings.Start_Min, currentSettings.Start_Var)
    end
    
    task.wait(GetRandomTime(startRange))
    local startIndex = (skipCount or 0) + 1
    
    for i = startIndex, #word do
        local char = word:sub(i,i):upper()
        local code = Enum.KeyCode[char] or (char == "-" and Enum.KeyCode.Minus)
        local charDelay = GetRandomTime(speedRange)
        
        if isFlex then
            if i > 2 and i < #word and (SafeRandom(1,1000)/1000) <= currentSettings.Flex_Typo then
                local wrongCode = Enum.KeyCode[string.char(SafeRandom(65, 90))]
                if wrongCode then 
                    SafeSendKey(wrongCode, true)
                    task.wait(SafeRandom(50, 150)/1000)
                    SafeSendKey(Enum.KeyCode.Backspace, true)
                end
            end
            if (SafeRandom(1,1000)/1000) <= currentSettings.Hesit_Chance then 
                task.wait(GetRandomTime(GetRange(currentSettings.Hesit_Val_Min, currentSettings.Hesit_Val_Var))) 
            end
            if (SafeRandom(1,1000)/1000) <= currentSettings.Flex_Burst then 
                charDelay = 0.02 
            end
        else
            if (SafeRandom(1,1000)/1000) <= currentSettings.Hesit_Chance then 
                task.wait(GetRandomTime({0.1, 0.2})) 
            end
        end
        
        if code then 
            pcall(function() 
                vim:SendKeyEvent(true, code, false, game)
                task.wait()
                vim:SendKeyEvent(false, code, false, game)
            end) 
        end
        task.wait(charDelay)
    end
    
    task.wait(0.1)
    SafeSendKey(Enum.KeyCode.Return, true)
    isTyping = false
end

local function DoSearch()
    if isTyping then 
        Status.Text = "Already typing..."
        Status.TextColor3 = Colors.Warning
        return 
    end
    
    local query = Sanitize(InputBox.Text)
    if query == "" then 
        Status.Text = "Enter a pattern..."
        Status.TextColor3 = Colors.Warning
        return 
    end
    
    Status.Text = "HUNTING..."
    Status.TextColor3 = Colors.Accent
    
    task.spawn(function()
        local candidates = {}
        local isTrap = TrapT.Text:find("ON")
        local isFirst = FirstT.Text:find("ON")
        local isShort = ShortT.Text:find("ON")
        local isFlex = FlexT.Text:find("ON")
        local isPsych = PsychT.Text:find("ON")
        
        for _, v in ipairs(ALL_WORDS) do
            local w = Sanitize(v)
            local wLow = w:lower()
            
            -- Validate English alphabet only
            if IsValidEnglishWord(w) and not CheckHist(w) and not IsBlacklisted(w) then
                local match = false
                if isFirst then
                    if wLow:sub(1, #query) == query then 
                        match = true 
                    end
                else
                    if wLow:find(query, 1, true) then 
                        match = true 
                    end
                end
                if match then 
                    table.insert(candidates, w)
                end
            end
        end
        
        local found = nil
        if #candidates > 0 then
            if isFlex then 
                local maxLen = 0
                for _, w in ipairs(candidates) do
                    if #w > maxLen then 
                        maxLen = #w
                        found = w
                    end
                end
            elseif isTrap or isPsych then
                local scoredCandidates = {}
                for _, w in ipairs(candidates) do
                    local score = 0
                    local last = w:sub(-1):lower()
                    local lastTwo = w:sub(-2):lower()
                    
                    if string.find("jqxz", last) then score = score + 100 end
                    if string.find("qkvw", last) then score = score + 50 end
                    if string.find("ersdty", last) then score = score - 100 end
                    
                    local replies = GetStartingCount(lastTwo)
                    if replies == 0 then 
                        score = score + 500
                    elseif replies < 5 then 
                        score = score + 200
                    elseif replies > 50 then 
                        score = score - 200
                    end
                    
                    score = score - (#w / 2)
                    table.insert(scoredCandidates, {word = w, score = score})
                end
                
                table.sort(scoredCandidates, function(a, b) return a.score > b.score end)
                
                if #scoredCandidates > 0 then
                    if isPsych and #scoredCandidates > 1 and math.random() < 0.4 then
                        local mercyIndex = math.min(#scoredCandidates, math.random(2, 3))
                        found = scoredCandidates[mercyIndex].word
                        GlobalEnv._UPB_Psych_State.Toying = true
                        Status.Text = "Psychological warfare active..."
                    else
                        found = scoredCandidates[1].word
                    end
                end
            elseif isShort then 
                local minLen = 999
                for _, w in ipairs(candidates) do
                    if #w < minLen then 
                        minLen = #w
                        found = w
                    end
                end
            else 
                found = candidates[math.random(#candidates)]
            end
            
            if not found and #candidates > 0 then 
                found = candidates[1]
            end
        end
        
        if found and IsValidEnglishWord(found) then
            lastFound = found
            AddHist(found)
            Status.Text = "TARGET: " .. found:upper()
            Status.TextColor3 = Colors.Success
            
            local skipAmt = 0
            if isFirst then skipAmt = #query end
            TypeWord(found, skipAmt)
        else 
            Status.Text = "NO VALID MATCH FOUND"
            Status.TextColor3 = Colors.Error
        end
    end)
end

KillBtn.MouseButton1Click:Connect(DoSearch)
InputBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then DoSearch() end
end)

-- Load dictionary with English validation
task.spawn(function()
    LoadConfig()
    local count = 0
    Status.Text = "Loading & Validating Dictionary..."
    Status.TextColor3 = Colors.Accent
    
    local WordCheck = {}
    for _, url in ipairs(DictionaryURLs) do
        local success, response = pcall(function()
            return game:HttpGet(url, true)
        end)
        
        if success and type(response) == "string" then
            for line in response:gmatch("[^\r\n]+") do
                local word = Sanitize(line)
                
                -- Only add if valid English word and meets length requirement
                if IsValidEnglishWord(word) and #word >= 5 then
                    local wordLower = word:lower()
                    if not WordCheck[wordLower] then
                        WordCheck[wordLower] = true
                        table.insert(ALL_WORDS, word)
                        count = count + 1
                        
                        local ending = word:sub(-2):lower()
                        if not WordEndings[ending] then
                            WordEndings[ending] = {}
                        end
                        table.insert(WordEndings[ending], word)
                    end
                end
            end
        end
        task.wait()
    end
    
    Status.Text = string.format("ARMED: %d VALID ENGLISH WORDS", count)
    Status.TextColor3 = Colors.Success
end)
