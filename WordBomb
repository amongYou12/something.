local FLEX_SETTINGS = { Speed_Min = 0.04, Speed_Var = 0.8, Start_Min = 0.05,  Start_Var = 1.0, Hesit_Chance = 0.45, Hesit_Val_Min = 0.1, Hesit_Val_Var = 1.2, Flex_Typo = 0.20, Flex_Burst = 0.15 }

local function GetRange(min, variancePercent) local m=tonumber(min) or .1; local v=tonumber(variancePercent) or 0; return {m, m+(m*v)} end

