-- SUPER FAST LOOKUP (BUCKET METHOD)
local function GetStartCount(prefix, limit)
    if not prefix or prefix == "" then return 999 end
    local pLow = prefix:lower()
    local bucketKey = pLow:sub(1, 2)
    local bucket = WORD_BUCKETS[bucketKey]
    
    if not bucket then return 0 end -- Empty bucket = 0 words
    
    local count = 0
    for _, w in ipairs(bucket) do
        if w:sub(1, #pLow):lower() == pLow then
            count = count + 1
            if count >= limit then return count end
        end
    end
    return count
end

local function FetchBlacklist(url, targetTable)
    local s, content = pcall(function() return game:HttpGet(url, true) end)
    if s and type(content) == "string" then
        for chunk in content:gmatch("[^,\n\r]+") do local cl=Sanitize(chunk):lower(); if cl~="" and IsValidEnglishWord(cl) then targetTable[cl]=true end end
    end
end

local function IsBlacklisted(w) local l=w:lower(); return SESSION_BLACKLIST[l] or (LL_Enabled and LL_Table[l]) or (WB_Enabled and WB_Table[l]) end

