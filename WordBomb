function SafeSendKey(key, hold) if not vim then return end; pcall(function() vim:SendKeyEvent(true, key, false, game); if hold then task.wait(0.02) end; vim:SendKeyEvent(false, key, false, game) end) end
function TypeWord(word, skipCount)
    if not vim then isTyping=false; return end
    isTyping = true
    local isFlex = FlexT.Text:find("ON")
    local currentSettings = isFlex and FLEX_SETTINGS or SETTINGS
    
    local speedRange = GetRange(currentSettings.Speed_Min, currentSettings.Speed_Var)
    local startRange = GetRange(currentSettings.Start_Min, currentSettings.Start_Var)
    
    task.wait(GetRandomTime(startRange))
    
    for i = (skipCount or 0) + 1, #word do
        local char = word:sub(i,i):upper()
        local code = Enum.KeyCode[char]
        local charDelay = GetRandomTime(speedRange)
        
        if isFlex then
            if i > 2 and i < #word and math.random() <= currentSettings.Flex_Typo then
                local wrongCode = Enum.KeyCode[string.char(SafeRandom(65, 90))]
                if wrongCode then SafeSendKey(wrongCode, true); task.wait(SafeRandom(50, 150)/1000); SafeSendKey(Enum.KeyCode.Backspace, true) end
            end
            if math.random() <= currentSettings.Flex_Burst then charDelay = 0.02 end
        end
        if math.random() <= currentSettings.Hesit_Chance then
            task.wait(GetRandomTime(GetRange(currentSettings.Hesit_Val_Min, currentSettings.Hesit_Val_Var)))
        end
        
        if code then pcall(function() vim:SendKeyEvent(true, code, false, game); task.wait(); vim:SendKeyEvent(false, code, false, game) end) end
        task.wait(charDelay)
    end
    
    task.wait(0.1)
    pcall(vim.SendKeyEvent, vim, true, Enum.KeyCode.Return, false, game); pcall(vim.SendKeyEvent, vim, false, Enum.KeyCode.Return, false, game)
    isTyping = false
end

function DoSearch() 
    if isTyping then return end
    local query = Sanitize(InputBox.Text:lower())
    if query == "" then return end
    Status.Text = "HUNTING..."
    
    task.spawn(function() 
        local candidates = {}
        local isTrap = TrapT.Text:find("ON")
        local isFirst = FirstT.Text:find("ON")
        local isShort = ShortT.Text:find("ON")
        local isFlex = FlexT.Text:find("ON")
        
        for _, v in ipairs(ALL_WORDS) do 
            local w = Sanitize(v)
            if IsValidEnglishWord(w) and not CheckHist(w) and not IsBlacklisted(w) then 
                local match = false
                if isFirst then 
                    if w:sub(1, #query) == query then match = true end 
                else 
                    if w:find(query, 1, true) then match = true end 
                end
                if match then table.insert(candidates, w) end 
            end 
        end
        
        local found
        if #candidates > 0 then 
            if isFlex then 
                local maxLen = 0
                for _, w in ipairs(candidates) do if #w > maxLen then maxLen = #w; found = w end end 
            elseif isTrap then 
                local inputLen = #query
                
                -- BUCKET OPTIMIZATION INSTEAD OF CULLING (NO FREEZE, 100% ACCURACY)
                local scored = {}
                for _, w in ipairs(candidates) do 
                    local score = 0
                    local suffixLen = math.min(inputLen, #w)
                    if suffixLen > 0 then
                        local suffix = w:sub(-suffixLen):lower()
                        if ALL_WORDS_SET[suffix] then score = score - 5000 end
                        local starts = GetStartCount(suffix, 10)
                        if starts == 0 then score = score - 5000 
                        elseif starts <= 5 then score = score + 1000
                        elseif starts <= 10 then score = score + 500
                        end
                        if suffix:find("[jqxz]") then score = score + 200 end
                    end
                    score = score - (#w/10)
                    table.insert(scored, {w=w, s=score}) 
                end
                table.sort(scored, function(a, b) return a.s > b.s end)
                
                if #scored > 0 then 
                    local toyChance = 0.1 + (#scored / 50)
                    if #scored > 3 and math.random() < math.min(toyChance, 0.6) then 
                        found = scored[math.random(math.floor(#scored * 0.6), #scored)].w
                        GlobalEnv._UPB_Psych_State.IsKillShot = true
                        Status.Text = "TOYING..." 
                    else 
                        found = scored[1].w 
                    end 
                end 
            elseif isShort then 
                local minLen = 999
                for _, w in ipairs(candidates) do if #w < minLen then minLen = #w; found = w end end 
            else 
                found = candidates[math.random(#candidates)] 
            end
            if not found then found = candidates[1] end 
        end
        
        if found then 
            lastFound = found
            AddHist(found)
            Status.Text = "TARGET: " .. found:upper()
            
            task.spawn(function()
                local suffix = found:sub(-math.min(#query, #found)):lower()
                local kills = GetStartCount(suffix, 999)
                local probability = 0
                if kills == 0 then probability = 100
                else probability = math.clamp(100 - (kills * 2), 5, 95) end
                
                local color = Colors.Success
                if probability > 50 then color = Colors.Warning end
                if probability > 90 then color = Colors.Fatal end
                
                ExecRateLabel.Text = "FATALITY PROBABILITY: " .. probability .. "% (" .. kills .. " REPLIES)"
                ExecRateLabel.TextColor3 = color
            end)
            
            TypeWord(found, isFirst and #query or 0) 
        else 
            Status.Text = "NO MATCH." 
        end 
    end) 
end
KillBtn.MouseButton1Click:Connect(DoSearch); InputBox.FocusLost:Connect(function(e) if e then DoSearch() end end)

