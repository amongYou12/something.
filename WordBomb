-- // 4. LOGIC FUNCTIONS // --

local function CheckHist(w) return GlobalEnv._UPB_History[w:lower()] end
local function AddHist(w) GlobalEnv._UPB_History[w:lower()] = true end
local function IsBlacklisted(w) local l=w:lower(); return SESSION_BLACKLIST[l] or (LL_Enabled and LL_Table[l]) or (WB_Enabled and WB_Table[l]) end

local function FetchWords(url) 
    local s,c = pcall(game.HttpGet, game, url, true)
    if s and type(c)=="string" then 
        for C in c:gmatch("[^%s]+") do 
            local cl=Sanitize(C):lower()
            if cl~="" and IsValidEnglishWord(cl) then 
                ALL_WORDS[cl]=true 
            end 
        end 
    end 
end

local function FindWord(pattern)
    local matches = {}
    pattern = pattern:lower()
    
    for word, _ in pairs(ALL_WORDS) do
        if word:find(pattern, 1, true) and not CheckHist(word) and not IsBlacklisted(word) then
            table.insert(matches, word)
        end
    end
    
    -- Sort by length based on mode
    table.sort(matches, function(a,b)
        if STATES.FlexMode then return #a > #b end -- Longest first for Flex
        return #a < #b -- Shortest first for Normal
    end)
    
    -- Return random from top 3 to look less robotic
    if #matches > 0 then
        return matches[math.random(1, math.min(3, #matches))]
    end
    return nil
end

local function TypeWord(word)
    if isTyping or not word then return end
    isTyping = true
    AddHist(word)
    
    local Conf = STATES.FlexMode and FLEX_SETTINGS or SETTINGS
    
    -- Start Delay
    task.wait(GetRandomTime(Conf.Start_Min, Conf.Start_Var))
    
    for i = 1, #word do
        if not isTyping then break end -- Killswitch
        
        local char = word:sub(i,i)
        local upper = char:upper()
        local vKey = Enum.KeyCode[upper]
        
        if vKey then
            vim:SendKeyEvent(true, vKey, false, game)
            task.wait()
            vim:SendKeyEvent(false, vKey, false, game)
        end
        
        -- Typing Speed & Hesitation
        local delay = GetRandomTime(Conf.Speed_Min, Conf.Speed_Var)
        
        if math.random() < Conf.Hesit_Chance then
            delay = delay + GetRandomTime(Conf.Hesit_Val_Min, Conf.Hesit_Val_Var)
        end
        
        task.wait(delay)
    end
    
    -- Submit
    if isTyping then
        vim:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
        task.wait()
        vim:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
    end
    
    isTyping = false
    lastFound = word
end

