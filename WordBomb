local function IsFunc(f) return type(f) == "function" end
local function IsTable(t) return type(t) == "table" end
local function Sanitize(s) if type(s) ~= "string" then return "" end; return s:gsub("%s+", ""):gsub("[^a-zA-Z]", "") end
local function IsValidEnglishWord(word) return type(word) == "string" and word:match("^[a-zA-Z]+$") end
local function GetRandomTime(min, var) 
    local m = tonumber(min) or 0.1
    local v = tonumber(var) or 0
    -- Calculate random variation
    local variation = m * v
    local actualMin = m
    local actualMax = m + variation
    return math.random(math.floor(actualMin*1000), math.floor(actualMax*1000))/1000 
end
local function SafeRandom(min, max) if not min then return 0 end; if not max then return math.random(min) end; if min > max then min, max = max, min end; return math.random(min, max) end

