local function IsFunc(f) return type(f) == "function" end
local function IsTable(t) return type(t) == "table" end

local function SafeRandom(min, max)
    if not min then return 0 end
    if not max then return math.random(min) end
    if min > max then min, max = max, min end
    return math.random(min, max)
end

local function GetRandomTime(tbl)
    if not IsTable(tbl) then return 0.1 end
    local v1 = tonumber(tbl[1]) or 0.1
    local v2 = tonumber(tbl[2]) or 0.2
    return SafeRandom(math.floor(v1*10000), math.floor(v2*10000)) / 10000
end

local function Sanitize(s) 
    if type(s) ~= "string" then return "" end
    return s:gsub("%s+", ""):gsub("[^a-zA-Z]", "")
end

local function IsValidEnglishWord(word)
    return type(word) == "string" and word:match("^[a-zA-Z]+$")
end

local function ShuffleTable(t)
    if not IsTable(t) then return end
    for i = #t, 2, -1 do
        local j = SafeRandom(1, i)
        t[i], t[j] = t[j], t[i]
    end
end

