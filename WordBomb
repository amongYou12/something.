local function CheckHist(w) return GlobalEnv._UPB_History[w:lower()] end
local function AddHist(w) GlobalEnv._UPB_History[w:lower()] = true end

local function FetchBlacklist(url, targetTable) 
    local s,c=pcall(function() return game:HttpGet(url, true) end)
    if s and type(c)=="string" then 
        for C in c:gmatch("[^,\n\r]+") do 
            local cl=Sanitize(C):lower(); 
            if cl~="" and IsValidEnglishWord(cl) then targetTable[cl]=true end 
        end 
    end 
end

local function IsBlacklisted(w) local l=w:lower(); return SESSION_BLACKLIST[l] or (LL_Enabled and LL_Table[l]) or (WB_Enabled and WB_Table[l]) end

-- DICTIONARY LOADER
local function LoadDictionary()
    if #ALL_WORDS > 1000 then return true end
    Status.Text = "LOADING DICTIONARY..."
    for _, url in pairs(DictionaryURLs) do
        local success, content = pcall(function() return game:HttpGet(url, true) end)
        if success and type(content) == "string" then
            for word in content:gmatch("[^\r\n]+") do
                local w = Sanitize(word)
                if IsValidEnglishWord(w) and w:len() >= 3 then
                    ALL_WORDS[w:lower()] = true
                end
            end
        end
    end
    Status.Text = "DICTIONARY LOADED: "..tostring(#ALL_WORDS)
    return true
end

