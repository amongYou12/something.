local function FindWord(pattern)
    local p = pattern:lower()
    if not WordEndings[p] then return nil end
    
    local potentialWords = {}
    for _, word in ipairs(WordEndings[p]) do
        if not CheckHist(word) and not IsBlacklisted(word) then
            table.insert(potentialWords, word)
        end
    end
    
    if #potentialWords == 0 then return nil end

    if GlobalEnv._UPB_Psych_State.IsKillShot then
        table.sort(potentialWords, function(a, b) return #a > #b end)
        return potentialWords[1]
    else
        return potentialWords[math.random(#potentialWords)]
    end
end

local function TypeWord(word)
    if isTyping or not word then return end
    isTyping = true
    
    local settings = isFlexMode and FLEX_SETTINGS or SETTINGS
    local startDelay = GetRandomTime(GetRange(settings.Start_Min, settings.Start_Var))
    task.wait(startDelay)
    
    local useBurst = isFlexMode and math.random() < settings.Flex_Burst
    
    for i = 1, #word do
        local char = word:sub(i,i)
        
        if isFlexMode and math.random() < settings.Flex_Typo then
            local typoChar = string.char(math.random(97, 122))
            vim:VirtualInputSend({typoChar})
            task.wait(GetRandomTime({0.08, 0.15}))
            vim:VirtualInputSend({Enum.KeyCode.Backspace})
            task.wait(GetRandomTime({0.05, 0.1}))
        end
        
        vim:VirtualInputSend({char})
        
        if math.random() < settings.Hesit_Chance then
            task.wait(GetRandomTime(GetRange(settings.Hesit_Val_Min, settings.Hesit_Val_Var)))
        end
        
        if not useBurst then
            local speed = GetRandomTime(GetRange(settings.Speed_Min, settings.Speed_Var))
            task.wait(speed)
        end
    end
    
    task.wait(GetRandomTime({0.05, 0.1}))
    vim:VirtualInputSend({Enum.KeyCode.Return})
    
    AddHist(word)
    lastFound = word
    Status.Text = "EXECUTED: " .. word
    isTyping = false
end

