local ConfigFile = "UPB_Config.json"
local HttpService = game:GetService("HttpService")

local function SaveConfig()
    if not writefile then 
        Status.Text = "Config save unavailable"
        Status.TextColor3 = Colors.Warning
        return 
    end
    local dataToSave = { Normal = SETTINGS, Flex = FLEX_SETTINGS }
    local s, e = pcall(HttpService.JSONEncode, HttpService, dataToSave)
    if s then 
        writefile(ConfigFile, e)
        Status.Text = "Config Saved"
        Status.TextColor3 = Colors.Success
        task.wait(1)
        Status.TextColor3 = Colors.SubText
    else 
        Status.Text = "Save failed"
        Status.TextColor3 = Colors.Error
    end
end

local function LoadConfig()
    if not isfile or not readfile then 
        Status.Text = "No file functions"
        return 
    end
    if not isfile(ConfigFile) then 
        Status.Text = "No saved config"
        return 
    end
    local s, e = pcall(readfile, ConfigFile)
    if not s or not e then return end
    local s, d = pcall(HttpService.JSONDecode, HttpService, e)
    if not s or not IsTable(d) then return end
    if IsTable(d.Normal) then for k, v in pairs(d.Normal) do SETTINGS[k] = v end end
    if IsTable(d.Flex) then for k, v in pairs(d.Flex) do FLEX_SETTINGS[k] = v end end
    
    -- Update slider visuals
    AllSliders["MIN SPEED"](SETTINGS.Speed_Min)
    AllSliders["SPEED VARIANCE"](SETTINGS.Speed_Var)
    AllSliders["START DELAY"](SETTINGS.Start_Min)
    AllSliders["DELAY VARIANCE"](SETTINGS.Start_Var)
    AllSliders["HESIT CHANCE"](SETTINGS.Hesit_Chance)
    AllSliders["HESIT VARIANCE"](SETTINGS.Hesit_Val_Var)
    AllSliders["FLEX MIN SPEED"](FLEX_SETTINGS.Speed_Min)
