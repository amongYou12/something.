    Trigger.BackgroundTransparency = 1
    Trigger.Text = ""
    
    local function UpdateVisual(val)
        local rX = (val - min) / (max - min)
        TweenService:Create(Fill, TweenInfo.new(0.2), {Size = UDim2.new(rX, 0, 1, 0)}):Play()
        ValueLabel.Text = string.format("%.2f", val)
    end
    
    AllSliders[name] = UpdateVisual
    
    local draggingS = false
    Trigger.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingS = true
            TweenService:Create(Fill, TweenInfo.new(0.1), {BackgroundTransparency = 0.3}):Play()
        end
    end)
    
    Trigger.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingS = false
            TweenService:Create(Fill, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
        end
    end)
    
